    "# Hyperparameter Tuning for Random Forest using RandomizedSearchCV\n",
    "\n",
    "# Initialize the base model\n",
    "rf_model = RandomForestClassifier(random_state=42)\n",
    "\n",
    "# Define the hyperparameter distributions to sample from\n",
    "param_dist = {\n",
    "    'n_estimators': [100, 200, 300, 400],       # number of trees\n",
    "    'max_depth': [None, 10, 20, 30],           # max depth of tree (None = no limit)\n",
    "    'min_samples_split': [2, 5, 10],           # min samples to split a node\n",
    "    'min_samples_leaf': [1, 2, 4],             # min samples at a leaf node\n",
    "    'max_features': ['sqrt', 'log2'],          # features considered at each split\n",
    "    'bootstrap': [True, False],                # bootstrap sampling for trees\n",
    "    'criterion': ['gini', 'entropy']           # splitting criterion\n",
    "}\n",
    "\n",
    "# Set up RandomizedSearchCV\n",
    "random_search = RandomizedSearchCV(\n",
    "    estimator=rf_model,\n",
    "    param_distributions=param_dist,\n",
    "    n_iter=50,              # try 50 random combinations (adjust for time constraints)\n",
    "    cv=5,                   # 5-fold cross-validation\n",
    "    scoring='accuracy',     # optimize for accuracy (we will check recall separately)\n",
    "    random_state=42,\n",
    "    n_jobs=-1               # use all CPU cores for speed\n",
    ")\n",
    "\n",
    "# Execute the search on the training set\n",
    "random_search.fit(X_train, y_train)\n",
    "\n",
    "# Output the best parameters and score from CV\n",
    "print(\"Best Hyperparameters:\", random_search.best_params_)\n",
    "print(\"Best CV Accuracy:\", f\"{random_search.best_score_:.4f}\")\n"
   ]
